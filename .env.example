# ==============================================================================
# JobOS Resume Builder v2.0 â€” Environment Variables
# Copy this to .env and fill in all values before running.
# ==============================================================================

# â”€â”€ LLM Providers â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Provider selection: "gemini" | "claude" | "deepseek"
LLM_EXTRACT_PROVIDER=gemini
LLM_REWRITE_PROVIDER=deepseek

# Gemini (default extract + ATS scoring)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_EXTRACT_MODEL=gemini-2.0-flash

# DeepSeek (default rewrite + quality check)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_REWRITE_MODEL=deepseek-chat

# Claude (fallback â€” keep populated for quality recovery)
ANTHROPIC_API_KEY=sk-ant-your-key-here
LLM_REWRITE_MODEL=claude-sonnet-4-6
LLM_EXTRACT_MODEL=claude-haiku-4-5-20251001

MAX_LLM_RETRIES=3
BEST_PRACTICE_MAX_TOKENS=3000

# â”€â”€ Auth / OTP â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
SESSION_SECRET=generate-a-random-32-char-string-here
SESSION_EXPIRY_HOURS=24

# â”€â”€ Email (OTP delivery + manual resume send) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD_ENCRYPTED=           # Use crypto.py to encrypt raw password
ENCRYPTION_KEY=                    # Fernet key â€” generate once, never regenerate

# â”€â”€ Payment â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Provider: "razorpay" | "stripe"
PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
RESUME_DOWNLOAD_PRICE_INR=99

# â”€â”€ Storage â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
SOURCE_FOLDER=C:\Users\K S S\jobs\input
DEST_FOLDER=C:\Users\K S S\jobs\output
DB_PATH=resume_builder.db

# â”€â”€ App â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
LOG_LEVEL=INFO
MAX_REVISIONS=3
